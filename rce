#!/usr/bin/env bash

set -uo pipefail

# Qoder CLI Installation Script v2.0.0
# - Version-managed storage: ~/.qoder/bin/qodercli/qodercli-[version]
# - User-space installation: ~/.local/bin/qodercli (no sudo required)
# - Automatic PATH configuration for supported shells
# - Installation logging: ~/.qoder/logs/qodercli_install_*.log

BASE_URL="https://qoder-ide.oss-accelerate.aliyuncs.com/qodercli"
FORCE=0
INSTALL_DIR="$HOME/.qoder"
BIN_DIR="$INSTALL_DIR/bin/qodercli"
LOCAL_BIN_DIR="$HOME/.local/bin"
BIN_LINK="$LOCAL_BIN_DIR/qodercli"
LOG_DIR="$INSTALL_DIR/logs"
INSTALL_METHOD="curl-bash"

# Installation state tracking
INSTALLED_VERSION=""
BINARY_PATH=""
PATH_CONFIGURED=0

export QODER_CLI_INSTALL=1

# Safe tput wrapper - returns empty string if tput is not available
# This handles minimal environments (Alpine, Docker containers) without ncurses
safe_tput() {
  if command -v tput >/dev/null 2>&1; then
    tput "$@" 2>/dev/null || true
  fi
}

usage() {
  cat <<EOF >&2
Qoder CLI Installation Script

USAGE:
  curl -fsSL ${BASE_URL}/install.sh | bash
  curl -fsSL ${BASE_URL}/install.sh | bash -s -- [OPTIONS]

OPTIONS:
  --force                Force overwrite existing installation
  -h, --help            Show this help message

EXAMPLES:
  # Standard installation
  curl -fsSL ${BASE_URL}/install.sh | bash

  # Force reinstall
  curl -fsSL ${BASE_URL}/install.sh | bash -s -- --force
EOF
}

# Parse command line arguments
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    --force)
      FORCE=1
      shift
      ;;
    *)
      echo "Error: Unknown option $1" >&2
      usage
      exit 1
      ;;
  esac
done

detect_os_arch() {
  local os arch
  os="$(uname -s | tr '[:upper:]' '[:lower:]')"
  arch="$(uname -m)"

  # macOS: detect Apple Silicon even when running under Rosetta 2.
  # Rosetta makes uname -m report "x86_64", but the real hardware is arm64.
  if [[ "$os" == "darwin" && "$arch" == "x86_64" ]]; then
    if sysctl -n hw.optional.arm64 2>/dev/null | grep -q '1'; then
      arch="arm64"
      echo "==> Detected Apple Silicon (running under Rosetta); selecting arm64 binary" >&2
    fi
  fi

  if [[ "$arch" == "aarch64" ]]; then
    arch="arm64"
  fi
  if [[ "$arch" == "x86_64" ]]; then
    arch="amd64"
  fi

  echo "$os $arch"
}

download() {
  local url="$1" output="$2"
  local max_retries=3
  local retry_count=0

  while [[ $retry_count -lt $max_retries ]]; do
    if [[ $retry_count -gt 0 ]]; then
      echo "Retry attempt $retry_count/$max_retries..." >&2
      sleep 2
    fi

    if command -v curl >/dev/null 2>&1; then
      if curl -fsSL --retry 2 --connect-timeout 30 --max-time 300 -H "User-Agent: qodercli-installer/curl-bash (https://qoder.com)" "$url" -o "$output"; then
        return 0
      fi
    elif command -v wget >/dev/null 2>&1; then
      if wget -q --tries=2 --connect-timeout=30 --read-timeout=300 --user-agent="qodercli-installer/curl-bash (https://qoder.com)" "$url" -O "$output"; then
        return 0
      fi
    else
      echo "Error: Neither curl nor wget is available" >&2
      exit 1
    fi

    # Clean up partial download on failure
    rm -f "$output" 2>/dev/null || true
    retry_count=$((retry_count + 1))
  done

  echo "Error: Failed to download $url after $max_retries attempts" >&2
  if command -v curl >/dev/null 2>&1; then
    echo "Using curl with retries and timeouts" >&2
  elif command -v wget >/dev/null 2>&1; then
    echo "Using wget with retries and timeouts" >&2
  fi
  exit 1
}

require_cmd() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "Error: $1 is required but not installed" >&2
    exit 1
  fi
}

# Fatal error - exit immediately with message
fatal_error() {
  echo "" >&2
  echo "❌ Fatal Error: $1" >&2
  if [[ $# -gt 1 ]]; then
    shift
    echo "" >&2
    echo "Suggestions:" >&2
    for suggestion in "$@"; do
      echo "  • $suggestion" >&2
    done
    echo "" >&2
  fi
  if [[ -n "${LOG_FILE:-}" ]]; then
    echo "Installation log: $LOG_FILE" >&2
    echo "" >&2
  fi
  echo "For help, visit: https://forum.qoder.com/c/bug-reports" >&2
  echo "" >&2
  exit 1
}

# Show final status with version info
show_final_status() {
  echo ""

  # Try to get version with fallback
  local version_output=""
  if [[ -x "$BIN_LINK" ]]; then
    version_output=$("$BIN_LINK" --version 2>/dev/null || echo "")
  fi

  if [[ -z "$version_output" && -n "$BINARY_PATH" && -x "$BINARY_PATH" ]]; then
    version_output=$("$BINARY_PATH" --version 2>/dev/null || echo "")
  fi

  if [[ -z "$version_output" && -n "$INSTALLED_VERSION" ]]; then
    version_output="qodercli version $INSTALLED_VERSION"
  fi

  local has_symlink=0
  local path_in_current_shell=0

  [[ -f "$BIN_LINK" ]] && has_symlink=1
  is_local_bin_in_path && path_in_current_shell=1

  # Determine installation status
  if [[ $has_symlink -eq 1 && $path_in_current_shell -eq 1 ]]; then
    # Perfect: can use immediately
    echo "🎉 ${version_output:-Qoder CLI} installed successfully!"
    echo ""
    echo "Get started: qodercli --help"
  elif [[ $has_symlink -eq 1 && $PATH_CONFIGURED -eq 1 ]]; then
    # Symlink exists, PATH configured in file, but not in current shell
    echo "🎉 ${version_output:-Qoder CLI} installed successfully!"
    echo ""
    echo "$(safe_tput bold)⚠️  Restart your terminal to use 'qodercli' command$(safe_tput sgr0)"
    echo ""
    echo "Use now (current terminal): $BINARY_PATH --help"
    echo "After restart: qodercli --help"
  elif [[ $has_symlink -eq 1 ]]; then
    # Symlink exists but PATH not configured
    echo "⚠️  ${version_output:-Qoder CLI} installed - manual setup required"
    echo ""
    echo "Use now: $BINARY_PATH --help"
    echo ""
    echo "$(safe_tput bold)To use 'qodercli' command:$(safe_tput sgr0)"
    echo "  Add to your shell config (~/.bashrc or ~/.zshrc):"
    echo "  export PATH=\"\$PATH:\$HOME/.local/bin\""
    echo "  Then restart your terminal"
  else
    # No symlink - need manual symlink creation
    echo "⚠️  ${version_output:-Qoder CLI} installed - manual setup required"
    echo ""
    echo "Use now: $BINARY_PATH --help"
    echo ""
    echo "$(safe_tput bold)To use 'qodercli' command:$(safe_tput sgr0)"
    if [[ $PATH_CONFIGURED -eq 1 ]]; then
      echo "  Create symlink:"
      echo "  ln -s $BINARY_PATH \$HOME/.local/bin/qodercli"
      echo "  Then restart your terminal"
    else
      echo "  1. Create directory and symlink:"
      echo "     mkdir -p \$HOME/.local/bin"
      echo "     ln -s $BINARY_PATH \$HOME/.local/bin/qodercli"
      echo "  2. Add to your shell config (~/.bashrc or ~/.zshrc):"
      echo "     export PATH=\"\$PATH:\$HOME/.local/bin\""
      echo "  3. Restart your terminal"
    fi
  fi

  echo ""
  # Show log file location if there were any issues or for reference
  if [[ -n "${LOG_FILE:-}" ]]; then
    if [[ $has_symlink -eq 0 || $path_in_current_shell -eq 0 ]]; then
      echo "Installation log: $LOG_FILE"
      echo ""
    fi
  fi
  echo "Need help? Visit: https://forum.qoder.com/c/bug-reports"
  echo ""
}

detect_shell() {
  local shell=""

  # Check environment variables
  if [[ -n "${SHELL:-}" ]]; then
    shell="$(basename "$SHELL")"
  elif [[ -n "${ZSH_VERSION:-}" ]]; then
    shell="zsh"
  elif [[ -n "${BASH_VERSION:-}" ]]; then
    shell="bash"
  elif [[ -n "${FISH_VERSION:-}" ]]; then
    shell="fish"
  fi

  # Normalize shell names
  case "${shell:-unknown}" in
    bash|bash.exe) echo "bash" ;;
    zsh|zsh.exe) echo "zsh" ;;
    fish|fish.exe) echo "fish" ;;
    ash|dash|sh) echo "sh" ;;
    *) echo "unknown" ;;
  esac
}

is_local_bin_in_path() {
  [[ ":$PATH:" == *":$HOME/.local/bin:"* ]]
}

get_shell_config() {
  local shell="$1"
  case "$shell" in
    bash)
      for config in "$HOME/.bashrc" "$HOME/.bash_profile" "$HOME/.profile"; do
        if [[ -f "$config" ]]; then
          echo "$config"
          return
        fi
      done
      # No existing config found, return default for this shell
      echo "$HOME/.bashrc"
      ;;
    zsh)
      for config in "$HOME/.zshrc" "$HOME/.zprofile" "$HOME/.profile"; do
        if [[ -f "$config" ]]; then
          echo "$config"
          return
        fi
      done
      # No existing config found, return default for this shell
      echo "$HOME/.zshrc"
      ;;
    fish)
      if [[ -f "$HOME/.config/fish/config.fish" ]]; then
        echo "$HOME/.config/fish/config.fish"
      else
        # No existing config found, return default for fish
        echo "$HOME/.config/fish/config.fish"
      fi
      ;;
    sh)
      for config in "$HOME/.profile" "$HOME/.bash_profile"; do
        if [[ -f "$config" ]]; then
          echo "$config"
          return
        fi
      done
      # No existing config found, return default for sh
      echo "$HOME/.profile"
      ;;
  esac
}

inject_path() {
  local shell="$1"

  if is_local_bin_in_path; then
    echo "==> ~/.local/bin already in PATH"
    PATH_CONFIGURED=1
    return 0
  fi

  if [[ "$shell" == "unknown" ]]; then
    echo ""
    echo "⚠️  Unknown shell detected. Please manually add to your shell config:"
    echo "   export PATH=\"\$PATH:$HOME/.local/bin\""
    echo ""
    return 1
  fi

  local config_file
  config_file="$(get_shell_config "$shell")"

  if [[ -z "$config_file" ]]; then
    echo "==> Warning: No shell config file found. Please manually add:"
    echo "==> export PATH=\"\$PATH:$HOME/.local/bin\""
    return 1
  fi

  # Check if config file is writable, create parent directory if needed
  local config_dir
  config_dir="$(dirname "$config_file")"
  if [[ ! -d "$config_dir" ]]; then
    if ! mkdir -p "$config_dir" 2>/dev/null; then
      echo "==> Warning: Cannot create config directory $config_dir" >&2
      echo "==> Please manually add: export PATH=\"\$PATH:$HOME/.local/bin\"" >&2
      return 1
    fi
  fi

  # Test if we can write to the config file
  if [[ -f "$config_file" ]] && [[ ! -w "$config_file" ]]; then
    echo "==> Warning: Config file $config_file is not writable" >&2
    echo "==> Please manually add: export PATH=\"\$PATH:$HOME/.local/bin\"" >&2
    return 1
  fi

  # Test write permission by trying to create/touch the file
  if ! touch "$config_file" 2>/dev/null; then
    echo "==> Warning: Cannot write to config file $config_file" >&2
    echo "==> Please manually add: export PATH=\"\$PATH:$HOME/.local/bin\"" >&2
    return 1
  fi

  local path_export
  if [[ "$shell" == "fish" ]]; then
    path_export="set -gx PATH \$PATH $HOME/.local/bin"
  else
    path_export="export PATH=\"\$PATH:$HOME/.local/bin\""
  fi

  # Check if already configured with precise regex
  if grep -Eqs '^[[:space:]]*(export[[:space:]]+PATH=.*\$PATH.*\$HOME|set[[:space:]]+-gx[[:space:]]+PATH.*\$HOME)[[:space:]]*\.local/bin' "$config_file"; then
    echo "==> PATH already configured in $config_file"
    PATH_CONFIGURED=1
    return 0
  fi

  # Add PATH export with error handling
  if ! {
    echo ""
    echo "# Added by Qoder CLI installer"
    echo "$path_export"
  } >> "$config_file" 2>/dev/null; then
    echo "==> Warning: Failed to write to config file $config_file" >&2
    echo "==> Please manually add: $path_export" >&2
    return 1
  fi

  echo "==> Added ~/.local/bin to PATH in $config_file"
  PATH_CONFIGURED=1
  echo ""
  # Bold text for main message
  echo "$(safe_tput bold)⚠️  Please restart your terminal to apply PATH changes$(safe_tput sgr0)"
  echo "   (Advanced: You can also run 'source $config_file' to apply immediately)"
  echo ""
}


install_binary() {
  local bin_name="$1"
  local version="$2"
  local tmpdir="$3"

  local version_bin="$BIN_DIR/qodercli-$version"
  BINARY_PATH="$version_bin"

  if [[ -e "$version_bin" && "$FORCE" != "1" ]]; then
    echo "Error: Version $version already exists. Use --force to overwrite." >&2
    return 1
  fi

  echo "==> Installing to $BIN_DIR"

  # Create BIN_DIR with proper error handling
  if ! mkdir -p "$BIN_DIR" 2>/dev/null; then
    echo "Error: Cannot create installation directory $BIN_DIR" >&2
    echo "Please check directory permissions and try again" >&2
    return 1
  fi

  # Move binary with error handling
  if ! mv "$tmpdir/$bin_name" "$version_bin" 2>/dev/null; then
    echo "Error: Failed to move binary to $version_bin" >&2
    echo "Please check directory permissions and available disk space" >&2
    return 1
  fi

  # Set executable permission with error handling
  if ! chmod +x "$version_bin" 2>/dev/null; then
    echo "Warning: Failed to set executable permission on $version_bin" >&2
    echo "You may need to manually run: chmod +x $version_bin" >&2
  fi

  echo "==> Installed to: $version_bin"

  # Create installation source marker with error handling
  local source_file="$BIN_DIR/.qodercli-install-resource"
  if echo "$INSTALL_METHOD" > "$source_file" 2>/dev/null; then
    echo "==> Created install source marker: $source_file"
  fi

  # Create LOCAL_BIN_DIR with proper error handling
  if ! mkdir -p "$LOCAL_BIN_DIR" 2>/dev/null; then
    echo "Warning: Cannot create local bin directory $LOCAL_BIN_DIR" >&2
    echo "Binary installed at: $version_bin" >&2
    echo "You may need to manually create the directory and symlink" >&2
    return 0
  fi

  # Remove existing link
  rm -f "$BIN_LINK" 2>/dev/null || true

  # Try symlink first, fallback to copy
  if ln -s "$version_bin" "$BIN_LINK" 2>/dev/null; then
    echo "==> Created symlink: $BIN_LINK -> $version_bin"
  else
    if cp "$version_bin" "$BIN_LINK" 2>/dev/null && chmod +x "$BIN_LINK" 2>/dev/null; then
      echo "==> Created copy: $BIN_LINK"
    else
      echo "Warning: Failed to create binary link at $BIN_LINK" >&2
      echo "Binary available at: $version_bin" >&2
      echo "You may need to manually create a symlink or add $BIN_DIR to your PATH" >&2
    fi
  fi
}

# Global variables for cleanup function
TMP_DIR=""

cleanup() {
  if [[ -n "$TMP_DIR" && -d "$TMP_DIR" ]]; then
    rm -rf "$TMP_DIR" 2>/dev/null || true
  fi
}

main() {
  # Early Windows detection - exit immediately without creating any files
  local os_name
  os_name="$(uname -s | tr '[:upper:]' '[:lower:]')"
  if [[ "$os_name" == *"mingw"* || "$os_name" == *"cygwin"* || "$os_name" == *"msys"* ]]; then
    echo "❌ Windows system detected." >&2
    echo "" >&2
    echo "This installer is designed for Unix-like systems (Linux/macOS)." >&2
    echo "For Windows support:" >&2
    echo "  • Use npm: npm install -g @qoder-ai/qodercli" >&2
    echo "  • Use WSL (Windows Subsystem for Linux)" >&2
    echo "  • Download binaries directly from releases page" >&2
    echo "" >&2
    echo "For help, visit: https://forum.qoder.com/c/bug-reports" >&2
    echo "" >&2
    exit 1
  fi

  # Setup logging directory and file
  if ! mkdir -p "$LOG_DIR" 2>/dev/null; then
    echo "Warning: Cannot create log directory $LOG_DIR" >&2
    echo "Installation will continue without logging" >&2
    LOG_FILE=""
  else
    local timestamp
    timestamp=$(date +%Y%m%d_%H%M%S)
    LOG_FILE="$LOG_DIR/qodercli_install_${INSTALL_METHOD}_${timestamp}.log"

    # Create log file
    if ! touch "$LOG_FILE" 2>/dev/null; then
      echo "Warning: Cannot create log file $LOG_FILE" >&2
      echo "Installation will continue without logging" >&2
      LOG_FILE=""
    else
      echo "Installation started at $(date -u +"%Y-%m-%dT%H:%M:%SZ")" > "$LOG_FILE"
      echo "Installation method: $INSTALL_METHOD" >> "$LOG_FILE"
      echo "================================" >> "$LOG_FILE"
      echo "" >> "$LOG_FILE"

      # Update symlink to point to latest log (any install method)
      local latest_log_link="$LOG_DIR/qodercli_install.log"
      rm -f "$latest_log_link" 2>/dev/null || true
      if ln -s "$LOG_FILE" "$latest_log_link" 2>/dev/null; then
        :
      fi

      # Redirect all output to both terminal and log file
      exec > >(tee -a "$LOG_FILE") 2>&1
    fi
  fi

  # Create temporary directory for all operations
  TMP_DIR="$(mktemp -d -t qoder-install.XXXXXX)"
  echo "==> Created temporary directory: $TMP_DIR"

  # Setup cleanup trap for production-grade error handling
  # Handle both normal exit and signal interruptions
  trap cleanup EXIT INT TERM

  local shell
  shell="$(detect_shell)"
  echo "==> Detected shell: $shell"

  local os arch
  read -r os arch < <(detect_os_arch)

  # On Linux x86_64, check if CPU supports AVX2 instructions.
  # Bun optimized binaries are compiled with -march=haswell, which requires
  # AVX2/BMI1/BMI2/FMA3. CPUs with only AVX1 (e.g. Ivy Bridge) will SIGILL.
  if [[ "$os" == "linux" && "$arch" == "amd64" ]]; then
    if [[ -f /proc/cpuinfo ]]; then
      if ! grep -qE '^flags[[:space:]]*:.*\bavx2\b' /proc/cpuinfo 2>/dev/null; then
        echo "==> CPU does not support AVX2; selecting baseline binary"
        arch="amd64-baseline"
      fi
    fi
  fi

  echo "==> Detected platform: $os/$arch"

  # Fetch manifest
  local manifest_url="$BASE_URL/channels/manifest.json"
  local manifest_file="$TMP_DIR/qoder-manifest.json"

  echo "==> Fetching release information..."
  if ! download "$manifest_url" "$manifest_file"; then
    fatal_error "Failed to download release manifest from $BASE_URL"
  fi

  # Parse manifest using awk/sed for minimal dependencies (no jq required)
  # This matches the actual manifest structure used by the update system
  local manifest_json
  manifest_json="$(cat "$manifest_file")"

  # Extract version from manifest
  local version
  version=$(printf '%s' "$manifest_json" | sed -n 's/.*"latest"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')

  if [[ -z "$version" ]]; then
    fatal_error "Cannot parse version from manifest"
  fi

  INSTALLED_VERSION="$version"
  echo "==> Latest version: $version"

  # Find matching file entry for current platform
  local entry
  entry=$(printf '%s' "$manifest_json" | tr -d '\n\r\t ' | sed 's/},{/}\n{/g' | grep -F "\"os\":\"$os\"" | grep -F "\"arch\":\"$arch\"" | head -n1)

  if [[ -z "$entry" ]]; then
    echo "" >&2
    if [[ -n "${LOG_FILE:-}" ]]; then
      echo "Installation log: $LOG_FILE" >&2
      echo "" >&2
    fi
    echo "For help, visit: https://forum.qoder.com/c/bug-reports" >&2
    echo "" >&2
    exit 1
  fi

  echo "==> Found binary for $os/$arch"

  # Extract URL and checksum from the matched entry
  local download_url checksum
  download_url=$(printf '%s' "$entry" | sed -n 's/.*"url"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
  checksum=$(printf '%s' "$entry" | sed -n 's/.*"sha256"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')

  if [[ -z "$download_url" ]]; then
    fatal_error "Missing download URL in manifest for ${os}/${arch}"
  fi

  echo "==> Downloading Qoder CLI $version..."

  local archive_filename
  archive_filename=$(basename "$download_url")
  local archive_file="$TMP_DIR/$archive_filename"

  # Check required extraction tool based on file extension
  if [[ "$archive_filename" =~ \.zip$ ]]; then
    require_cmd unzip
  elif [[ "$archive_filename" =~ \.(tar\.gz|tgz)$ ]]; then
    require_cmd tar
  else
    fatal_error "Unsupported archive format: $archive_filename"
  fi

  if ! download "$download_url" "$archive_file"; then
    fatal_error "Failed to download binary from $download_url"
  fi

  # Verify file was downloaded and has reasonable size
  if [[ ! -f "$archive_file" ]]; then
    fatal_error "Downloaded file not found: $archive_file"
  fi

  local file_size
  file_size=$(wc -c < "$archive_file" 2>/dev/null || echo "0")
  if [[ "$file_size" -lt 1024 ]]; then
    fatal_error "Downloaded file is too small ($file_size bytes), likely corrupted"
  fi

  echo "==> Downloaded file size: $file_size bytes"

  # Verify checksum
  if [[ -n "$checksum" ]]; then
    echo "==> Verifying checksum..."
    local checksum_verified=0
    local checksum_file="$TMP_DIR/$(basename "$archive_file").sha256"

    # Create checksum file for verification (more reliable than echo | -c)
    # Use basename to ensure -c works correctly with relative paths
    printf '%s  %s\n' "$checksum" "$(basename "$archive_file")" > "$checksum_file"

    # Run verification in the same directory as the files
    if command -v shasum >/dev/null 2>&1; then
      if (cd "$TMP_DIR" && shasum -a 256 -c "$(basename "$checksum_file")") >/dev/null 2>&1; then
        checksum_verified=1
      fi
    elif command -v sha256sum >/dev/null 2>&1; then
      if (cd "$TMP_DIR" && sha256sum -c "$(basename "$checksum_file")") >/dev/null 2>&1; then
        checksum_verified=1
      fi
    else
      echo "Warning: No checksum verification tool available (shasum or sha256sum)" >&2
    fi

    if [[ $checksum_verified -eq 1 ]]; then
      echo "==> Checksum verified"
    else
      # Show actual checksum for debugging
      local actual_checksum=""
      if command -v shasum >/dev/null 2>&1; then
        actual_checksum=$(shasum -a 256 "$archive_file" 2>/dev/null | cut -d' ' -f1 || echo "unknown")
      elif command -v sha256sum >/dev/null 2>&1; then
        actual_checksum=$(sha256sum "$archive_file" 2>/dev/null | cut -d' ' -f1 || echo "unknown")
      fi

      echo "" >&2
      echo "❌ Fatal Error: Checksum verification failed" >&2
      echo "" >&2
      echo "Expected: $checksum" >&2
      echo "Actual:   ${actual_checksum:-unknown}" >&2
      echo "" >&2
      echo "The downloaded file may be corrupted. Please try again." >&2
      echo "" >&2
      if [[ -n "${LOG_FILE:-}" ]]; then
        echo "Installation log: $LOG_FILE" >&2
        echo "" >&2
      fi
      echo "For help, visit: https://forum.qoder.com/c/bug-reports" >&2
      echo "" >&2
      exit 1
    fi
  fi

  # Extract archive
  echo "==> Extracting archive..."
  local extract_dir="$TMP_DIR/extract"
  if ! mkdir -p "$extract_dir" 2>/dev/null; then
    fatal_error "Cannot create extraction directory"
  fi

  # Extract based on file extension
  if [[ "$archive_filename" =~ \.zip$ ]]; then
    if ! unzip -q "$archive_file" -d "$extract_dir" 2>/dev/null; then
      fatal_error "Failed to extract zip archive"
    fi
  elif [[ "$archive_filename" =~ \.(tar\.gz|tgz)$ ]]; then
    if ! tar -xzf "$archive_file" -C "$extract_dir" 2>/dev/null; then
      fatal_error "Failed to extract tar.gz archive"
    fi
  else
    fatal_error "Unsupported archive format: $archive_filename"
  fi

  local bin_name="qodercli"
  if [[ "$os" == "windows" ]]; then
    bin_name="qodercli.exe"
  fi

  if [[ ! -f "$extract_dir/$bin_name" ]]; then
    fatal_error "Binary $bin_name not found in archive"
  fi

  # Install binary
  if ! install_binary "$bin_name" "$version" "$extract_dir"; then
    echo "" >&2
    echo "Installation failed. Check the log for details: $LOG_FILE" >&2
    echo "For help, visit: https://forum.qoder.com/c/bug-reports" >&2
    exit 1
  fi

  # Configure PATH (non-fatal)
  inject_path "$shell" || true

  # Show final status with version
  show_final_status
}

main "$@"
